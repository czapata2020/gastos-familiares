# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env en el servidor de producción y completa los valores.
# NUNCA subas .env al repositorio (ya está en .gitignore).
# Docker Compose carga .env automáticamente desde el mismo directorio.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Deploy ───────────────────────────────────────────────────────────────────
# Tag de las imágenes GHCR a desplegar. Usa "latest" o un tag específico (ej: sha-a1b2c3d).
TAG=latest

# ─── OpenAI / modelo compatible ───────────────────────────────────────────────
# Base URL del endpoint. Cambia solo aquí para apuntar a un modelo local
# (Ollama, LM Studio, etc.) sin modificar el workflow de n8n.
OPENAI_BASE_URL=https://api.openai.com/v1

# Modelo a usar — debe soportar visión (image_url en content)
MODEL_NAME=gpt-4o

# API key. En producción carga la credencial directamente en la UI de n8n.
OPENAI_API_KEY=sk-...

# ─── n8n ──────────────────────────────────────────────────────────────────────
# URL pública desde la que WAHA alcanza los webhooks de n8n
N8N_WEBHOOK_URL=http://localhost:5678

# Autenticación básica para la UI de n8n (recomendado en producción)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiame

# ─── WAHA ─────────────────────────────────────────────────────────────────────
# Motor: WEBJS (predeterminado, con Chromium) o NOWEB (más ligero)
WAHA_ENGINE=WEBJS
WAHA_SESSION=default

# ─── SMTP (opcional) ──────────────────────────────────────────────────────────
# Solo necesario si no configuras SMTP desde la UI (Configuración → SMTP en Vault).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=app-password-de-google
# SMTP_FROM=tu@gmail.com
